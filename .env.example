# =============================================
# Maktab Market — Muhit o'zgaruvchilari
# =============================================
# Bu faylni nusxalab ".env" deb saqlang
# cp .env.example .env

# --- TELEGRAM BOT ---
# 1. @BotFather ga yozing, /newbot buyrug'i bering
# 2. Bot token oling (masalan: 7123456789:AAHxxxxxx)
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here

# 3. Botni kanalga/guruhga qo'shing
# 4. https://api.telegram.org/bot<TOKEN>/getUpdates ga kiring
# 5. "chat":{"id": ...} qiymatini oling
VITE_TELEGRAM_CHAT_ID=your_chat_id_here

# --- TO'LOV TIZIMLARI ---
# Click (https://click.uz/uz/business)
VITE_CLICK_SERVICE_ID=your_click_service_id
VITE_CLICK_MERCHANT_ID=your_click_merchant_id

# Payme (https://merchant.payme.uz)
VITE_PAYME_MERCHANT_ID=your_payme_merchant_id

# Uzum Bank
VITE_UZUM_STORE_ID=your_uzum_store_id
